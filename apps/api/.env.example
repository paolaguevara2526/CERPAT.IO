# apps/api/.env.example
# Copiar a .env y completar con los valores reales. NUNCA subir el .env real al repositorio.

DATABASE_URL="postgresql://usuario:password@host:5432/planeador?schema=public"
PORT=4000
CORS_ORIGIN="https://app.cerpat.io,http://localhost:3000"

# Autenticación (Auth.js / Clerk — completar según el proveedor elegido)
AUTH_SECRET=

# Microsoft 365 / Graph API (envío de correo vía notificaciones@cerpat.io)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX=notificaciones@cerpat.io

# Sentry
SENTRY_DSN=
